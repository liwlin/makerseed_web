<view class="page signup-page">
  <view class="video-card card">
    <image class="video-bg" src="{{media.handsOn}}" mode="aspectFill"></image>
    <view class="video-mask"></view>
    <image class="video-logo" src="{{media.logoHorizontal}}" mode="aspectFit"></image>
    <view class="video-title">课程报名</view>
    <view class="video-subtitle">设计 · 建造 · 编程 · 调试 · 反思 · 改进</view>
  </view>

  <view class="path-list">
    <view
      class="path-card {{item.color}}"
      wx:for="{{cards}}"
      wx:key="title"
      data-group="{{item.group}}"
      bindtap="viewGroup"
    >
      <view>
        <view class="path-title">{{item.title}}</view>
        <view class="path-desc">{{item.desc}}</view>
      </view>
      <view class="path-button">查看</view>
    </view>
  </view>

  <view class="family-section">
    <view class="section-title">五大课程方向</view>
    <scroll-view scroll-x class="family-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="family-card"
        wx:for="{{courseFamilies}}"
        wx:key="id"
        style="border-color: {{item.color}};"
      >
        <image src="{{item.image}}" mode="aspectFill"></image>
        <view class="family-dot" style="background: {{item.color}};"></view>
        <view class="family-title">{{item.title}}</view>
        <view class="family-subtitle">{{item.subtitle}}</view>
        <view class="family-age">{{item.startAge}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="project-section">
    <view class="section-title">项目制造物主题</view>
    <view class="poster-card card" wx:for="{{projectPosters}}" wx:key="title">
      <image src="{{item.image}}" mode="aspectFill"></image>
      <view>
        <view class="poster-title">{{item.title}}</view>
        <view class="poster-subtitle">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view class="article-section">
    <view class="article-title">官方课程资料</view>
    <view
      class="article-card card"
      wx:for="{{articleMaterials}}"
      wx:key="id"
      data-link="{{item.link}}"
      bindtap="copyArticle"
    >
      <view class="article-cover" style="background-image: url({{item.cover}});"></view>
      <view class="article-main">
        <view class="article-name">{{item.title}}</view>
        <view class="article-desc">{{item.desc}}</view>
        <view class="article-date">{{item.publishedAt}}</view>
      </view>
      <view class="article-action">复制</view>
    </view>
  </view>

  <view class="intro-card card">
    <view class="intro-title">校区简介</view>
    <view class="intro-text">
      {{siteConfig.brandName}}位于{{siteConfig.region}}，{{siteConfig.positioning}}孩子将在真实项目中学习设计、建造、编程、调试与复盘。
    </view>
  </view>

  <button class="primary-button fixed-main" bindtap="goBooking">立即报名</button>
</view>
