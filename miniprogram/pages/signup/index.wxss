.signup-page {
  padding-bottom: 150rpx;
}

.video-card {
  display: grid;
  place-items: center;
  min-height: 420rpx;
  padding: 48rpx 36rpx;
  background: #f7f7f7;
}

.video-card image {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 18rpx;
}

.video-title {
  font-size: 44rpx;
  font-weight: 950;
}

.video-subtitle {
  margin-top: 12rpx;
  color: #888888;
  font-size: 27rpx;
  line-height: 1.5;
  text-align: center;
}

.path-list {
  display: grid;
  gap: 28rpx;
  margin-top: 46rpx;
}

.path-card {
  display: grid;
  grid-template-columns: 1fr 190rpx;
  align-items: center;
  min-height: 152rpx;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.13);
}

.path-card > view:first-child {
  padding-left: 40rpx;
}

.path-card.purple {
  color: #ffffff;
  background: #4b1f68;
}

.path-card.orange {
  color: #ffffff;
  background: #ff5a36;
}

.path-card.violet {
  color: #ffffff;
  background: #8f3dd6;
}

.path-title {
  font-size: 36rpx;
  font-weight: 950;
}

.path-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.path-button {
  display: grid;
  place-items: center;
  height: 152rpx;
  border-top-left-radius: 70rpx;
  border-bottom-left-radius: 70rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 38rpx;
  font-weight: 950;
}

.orange .path-button {
  background: #ff9632;
}

.violet .path-button {
  background: #4b1f68;
}

.article-section {
  display: grid;
  gap: 20rpx;
  margin-top: 46rpx;
}

.article-title {
  font-size: 38rpx;
  font-weight: 950;
}

.article-card {
  display: grid;
  grid-template-columns: 150rpx 1fr 92rpx;
  gap: 20rpx;
  align-items: center;
  min-height: 150rpx;
  padding: 20rpx;
}

.article-cover {
  width: 150rpx;
  height: 110rpx;
  border-radius: 18rpx;
  background-color: #e8eef5;
  background-position: center;
  background-size: cover;
}

.article-name {
  color: #23112f;
  font-size: 29rpx;
  line-height: 1.28;
  font-weight: 950;
}

.article-desc {
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
  line-height: 1.35;
}

.article-date {
  margin-top: 8rpx;
  color: #9a42df;
  font-size: 23rpx;
  font-weight: 850;
}

.article-action {
  display: grid;
  place-items: center;
  min-height: 62rpx;
  border-radius: 22rpx;
  color: #ffffff;
  background: #ff5a36;
  font-size: 25rpx;
  font-weight: 900;
}

.intro-card {
  margin-top: 46rpx;
  padding: 36rpx;
  text-align: center;
}

.intro-title {
  color: #888888;
  font-size: 42rpx;
  font-weight: 900;
}

.intro-text {
  margin-top: 22rpx;
  color: #777777;
  font-size: 28rpx;
  line-height: 1.65;
  text-align: left;
}

.fixed-main {
  position: fixed;
  right: 50rpx;
  bottom: 38rpx;
  left: 50rpx;
  z-index: 10;
}
