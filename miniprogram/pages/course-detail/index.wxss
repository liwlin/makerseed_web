.detail-page {
  padding-bottom: 150rpx;
}

.detail-hero {
  padding: 32rpx 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #075f9b 0%, #0079c8 100%);
}

.group-hero {
  border-radius: 30rpx;
  background: linear-gradient(135deg, #4b1f68 0%, #8f3dd6 100%);
}

.detail-tag {
  display: inline-flex;
  padding: 7rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 24rpx;
  font-weight: 900;
}

.detail-title {
  margin-top: 26rpx;
  font-size: 50rpx;
  line-height: 1.15;
  font-weight: 950;
}

.detail-meta {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  font-weight: 800;
}

.detail-summary {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 28rpx;
  line-height: 1.7;
}

.section-block {
  margin-top: 22rpx;
  padding: 26rpx;
}

.group-list {
  display: grid;
  gap: 28rpx;
  margin-top: 34rpx;
}

.group-course {
  display: grid;
  grid-template-columns: 118rpx 1fr 118rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 154rpx;
  padding: 24rpx;
}

.course-dot {
  width: 98rpx;
  height: 98rpx;
  border: 12rpx solid #ffffff;
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.16);
}

.group-course-title {
  font-size: 32rpx;
  font-weight: 950;
}

.group-course-subtitle {
  margin-top: 8rpx;
  color: #888888;
  font-size: 25rpx;
}

.group-course-fit {
  margin-top: 6rpx;
  color: #8f3dd6;
  font-size: 25rpx;
  font-weight: 850;
}

.check-button {
  min-height: 74rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: #ff5a36;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 74rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.list-item {
  position: relative;
  padding: 16rpx 0 16rpx 32rpx;
  border-bottom: 1rpx solid #e6eef6;
  color: #34465a;
  font-size: 28rpx;
  line-height: 1.55;
}

.list-item:last-child {
  border-bottom: 0;
}

.list-item::before {
  position: absolute;
  top: 30rpx;
  left: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #25a66a;
  content: "";
}

.project-grid,
.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.project-item,
.keyword {
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  color: #26384d;
  background: #f2f7fb;
  font-size: 26rpx;
  font-weight: 750;
}

.keyword {
  color: #075f9b;
  background: #e8f5ff;
}

.fixed-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 16rpx;
  padding: 18rpx 28rpx 34rpx;
  border-top: 1rpx solid #d9e4ee;
  background: rgba(255, 255, 255, 0.96);
}

.action {
  min-height: 88rpx;
  line-height: 88rpx;
}
