<view class="page detail-page" wx:if="{{group}}">
  <view class="detail-hero group-hero">
    <view class="detail-tag">课程分类</view>
    <view class="detail-title">{{group.label}}</view>
    <view class="detail-meta">{{group.subtitle}}</view>
    <view class="detail-summary">{{group.intro}}</view>
  </view>

  <view class="matrix-card card">
    <view class="matrix-head">
      <view>年级</view>
      <view>适合课程</view>
    </view>
    <view class="matrix-row" wx:for="{{group.matrix}}" wx:key="grade">
      <view>{{item.grade}}</view>
      <view>{{item.course}}</view>
    </view>
  </view>

  <scroll-view class="badge-scroll" scroll-x enable-flex>
    <view class="badge-track">
      <view
        class="course-badge {{activeCourse.id === item.id ? 'active' : ''}}"
        wx:for="{{group.courses}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectGroupCourse"
      >
        <view class="badge-circle" style="background: {{item.accent}}">
          <text>{{item.short}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="active-course card" wx:if="{{activeCourse}}">
    <view class="active-top">
      <view class="active-dot" style="background: {{activeCourse.accent}}"></view>
      <view>
        <view class="active-title">{{activeCourse.title}}</view>
        <view class="active-subtitle">{{activeCourse.subtitle}}</view>
        <view class="active-fit">{{activeCourse.fit}}</view>
      </view>
    </view>
    <view class="outcome-list">
      <view class="list-item" wx:for="{{activeCourse.outcomes}}" wx:key="*this">{{item}}</view>
    </view>
    <button class="check-button" data-title="{{activeCourse.title}}" bindtap="bookCourse">报名这个课程</button>
  </view>

  <view class="package-card card">
    <view class="block-title">材料 + 教材 + 课后任务</view>
    <view class="package-grid">
      <view class="package-item" wx:for="{{group.packageItems}}" wx:key="*this">
        <view class="package-index">{{index + 1}}</view>
        <view>{{item}}</view>
      </view>
    </view>
  </view>

  <view class="setup-card card">
    <view class="block-title">班级配置</view>
    <view class="setup-row" wx:for="{{group.classSetup}}" wx:key="*this">
      <text></text>
      <view>{{item}}</view>
    </view>
  </view>

  <view class="fixed-actions">
    <button class="ghost-button action" data-title="{{activeCourse.title}}" bindtap="bookCourse">预约面谈</button>
    <button class="primary-button action" data-title="{{activeCourse.title}}" bindtap="bookCourse">报名课程</button>
  </view>
</view>

<view class="page detail-page" wx:if="{{course}}">
  <view class="detail-hero card">
    <view class="detail-tag">{{course.tag}}</view>
    <view class="detail-title">{{course.title}}</view>
    <view class="detail-meta">{{course.age}} · 项目制学习</view>
    <view class="detail-summary">{{course.summary}}</view>
  </view>

  <view class="source-card card" wx:if="{{course.source}}">
    <view class="source-cover" style="background-image: url({{course.source.cover}});"></view>
    <view class="source-main">
      <view class="source-label">公众号课程资料</view>
      <view class="source-title">{{course.source.title}}</view>
      <view class="source-desc">{{course.source.desc}}</view>
      <view class="source-date">{{course.source.publishedAt}}</view>
    </view>
  </view>

  <view class="section-block card">
    <view class="block-title">适合收获</view>
    <view class="list-item" wx:for="{{course.outcomes}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="section-block card">
    <view class="block-title">典型项目</view>
    <view class="project-grid">
      <view class="project-item" wx:for="{{course.projects}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="section-block card">
    <view class="block-title">课堂关键词</view>
    <view class="keyword-row">
      <view class="keyword" wx:for="{{course.points}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="package-card card">
    <view class="block-title">材料 + 教材 + 课后任务</view>
    <view class="package-grid">
      <view class="package-item" wx:for="{{course.packageItems}}" wx:key="*this">
        <view class="package-index">{{index + 1}}</view>
        <view>{{item}}</view>
      </view>
    </view>
  </view>

  <view class="setup-card card">
    <view class="block-title">班级配置</view>
    <view class="setup-row" wx:for="{{course.classSetup}}" wx:key="*this">
      <text></text>
      <view>{{item}}</view>
    </view>
  </view>

  <view class="fixed-actions">
    <button class="ghost-button action" bindtap="copyLink">复制原文</button>
    <button class="primary-button action" bindtap="bookCourse">预约这个课程</button>
  </view>
</view>
