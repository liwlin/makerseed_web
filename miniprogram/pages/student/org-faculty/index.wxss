.subnav {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
}

.sub-title {
  flex-shrink: 0;
  color: #1a2330;
  font-size: 27rpx;
  font-weight: 900;
}

.toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  flex: 1;
  gap: 6rpx;
  padding: 6rpx;
  border-radius: 22rpx;
  background: #eef1f4;
}

.toggle view {
  display: grid;
  place-items: center;
  min-height: 52rpx;
  border-radius: 16rpx;
  color: #8a94a3;
  font-size: 23rpx;
  font-weight: 800;
}

.toggle .active {
  color: #0079c8;
  background: #ffffff;
}

.faculty-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.faculty-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx;
}

.faculty-card image {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 22rpx;
}

.faculty-main {
  flex: 1;
  min-width: 0;
}

.name {
  color: #1a2330;
  font-size: 28rpx;
  font-weight: 900;
}

.role {
  margin-top: 4rpx;
  color: #ff5a36;
  font-size: 21rpx;
  font-weight: 800;
}

.desc {
  margin-top: 5rpx;
  color: #8a94a3;
  font-size: 20rpx;
  line-height: 1.35;
}

.green {
  margin: 28rpx 0 16rpx;
  color: #247d34;
}

.rnd-card {
  overflow: hidden;
}

.rnd-card image {
  display: block;
  width: 100%;
  max-height: 240rpx;
}

.rnd-bottom {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 24rpx;
}

.rnd-bottom text {
  color: #5d6b7a;
  font-size: 22rpx;
  font-weight: 700;
}

.rnd-bottom view {
  color: #0079c8;
  font-size: 22rpx;
  font-weight: 800;
}
