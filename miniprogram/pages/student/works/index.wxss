.course-system-page {
  padding-top: 26rpx;
}

.page-title {
  color: #1a2330;
  font-size: 38rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 25rpx;
}

.family-list {
  display: grid;
  gap: 18rpx;
  margin-top: 30rpx;
}

.family-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 126rpx;
  padding: 20rpx 26rpx;
  border-left: 6rpx solid #39B0E3;
  border-radius: 26rpx;
  background: #ffffff;
}

.family-icon {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.family-main {
  flex: 1;
  min-width: 0;
}

.family-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.family-title {
  color: #1a2330;
  font-size: 29rpx;
  font-weight: 900;
}

.age-pill {
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  font-size: 19rpx;
  font-weight: 900;
}

.family-desc {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 23rpx;
}

.poster-label {
  margin: 34rpx 0 18rpx;
  color: #ff5a36;
  font-family: "Menlo", "Consolas", monospace;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.poster-row {
  display: flex;
  gap: 18rpx;
  overflow: hidden;
}

.poster-row image {
  flex: 1;
  height: 220rpx;
  min-width: 0;
  border: 1rpx solid #dce3ea;
  border-radius: 18rpx;
  background: #ffffff;
}
