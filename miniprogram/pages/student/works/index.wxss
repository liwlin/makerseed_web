.course-system-page {
  padding-top: 26rpx;
}

.page-title {
  color: #1a2330;
  font-size: 38rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 25rpx;
}

.family-list {
  display: grid;
  gap: 18rpx;
  margin-top: 30rpx;
}

.family-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 126rpx;
  padding: 20rpx 26rpx;
  border-left: 6rpx solid #39B0E3;
  border-radius: 26rpx;
  background: #ffffff;
}

.family-icon {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
}

.course-glyph {
  width: 40rpx;
  height: 40rpx;
}

.text-glyph {
  display: grid;
  place-items: center;
  width: 52rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.robot-glyph {
  display: grid;
  place-items: center;
  gap: 5rpx;
  padding: 6rpx;
  border: 4rpx solid currentColor;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.robot-eyes {
  display: flex;
  gap: 8rpx;
}

.robot-eyes text {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: currentColor;
}

.robot-mouth {
  width: 18rpx;
  height: 4rpx;
  border-radius: 6rpx;
  background: currentColor;
}

.chip-glyph {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.chip-core {
  width: 15rpx;
  height: 15rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.chip-pin-row {
  display: flex;
  gap: 5rpx;
}

.chip-pin-row text {
  width: 5rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.model-glyph {
  position: relative;
}

.model-line {
  position: absolute;
  left: 17rpx;
  top: 10rpx;
  width: 5rpx;
  height: 26rpx;
  border-radius: 5rpx;
  background: currentColor;
  transform-origin: top center;
}

.model-line-left {
  transform: rotate(55deg);
}

.model-line-right {
  transform: rotate(-55deg);
}

.model-glyph text {
  position: absolute;
  width: 13rpx;
  height: 13rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.model-glyph text:nth-child(3) {
  left: 13rpx;
  top: 0;
}

.model-glyph text:nth-child(4) {
  left: 0;
  bottom: 0;
}

.model-glyph text:nth-child(5) {
  right: 0;
  bottom: 0;
}

.family-main {
  flex: 1;
  min-width: 0;
}

.family-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.family-title {
  color: #1a2330;
  font-size: 29rpx;
  font-weight: 900;
}

.age-pill {
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  font-size: 19rpx;
  font-weight: 900;
}

.family-desc {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 23rpx;
}

.poster-label {
  margin: 34rpx 0 18rpx;
  color: #ff5a36;
  font-family: "Menlo", "Consolas", monospace;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.poster-row {
  display: flex;
  gap: 18rpx;
  overflow: hidden;
}

.poster-row image {
  flex: 1;
  height: 220rpx;
  min-width: 0;
  border: 1rpx solid #dce3ea;
  border-radius: 18rpx;
  background: #ffffff;
}
