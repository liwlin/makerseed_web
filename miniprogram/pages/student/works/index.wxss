.course-system-page {
  padding-top: 26rpx;
}

.page-title {
  color: #1a2330;
  font-size: 38rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 25rpx;
}

.family-list {
  display: grid;
  gap: 18rpx;
  margin-top: 30rpx;
}

.family-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 126rpx;
  padding: 20rpx 26rpx;
  border-left: 6rpx solid #39B0E3;
  border-radius: 26rpx;
  background: #ffffff;
}

.family-icon {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
}

.course-glyph {
  width: 40rpx;
  height: 40rpx;
}

.robot-glyph {
  position: relative;
}

.robot-sensor {
  position: absolute;
  left: 17rpx;
  top: 0;
  width: 6rpx;
  height: 6rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.robot-stem {
  position: absolute;
  left: 19rpx;
  top: 9rpx;
  width: 3rpx;
  height: 7rpx;
  border-radius: 3rpx;
  background: currentColor;
}

.robot-body {
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 23rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.robot-body text {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: currentColor;
}

.code-glyph {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 48rpx;
  font-family: "Menlo", "Consolas", monospace;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.chip-glyph {
  position: relative;
}

.chip-box {
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.pin {
  position: absolute;
  border-radius: 4rpx;
  background: currentColor;
}

.pin.top,
.pin.bottom {
  width: 4rpx;
  height: 8rpx;
}

.pin.left,
.pin.right {
  width: 8rpx;
  height: 4rpx;
}

.pin.top {
  top: 1rpx;
}

.pin.bottom {
  bottom: 1rpx;
}

.pin.left {
  left: 1rpx;
}

.pin.right {
  right: 1rpx;
}

.pin.top.pin-a,
.pin.bottom.pin-a {
  left: 12rpx;
}

.pin.top.pin-b,
.pin.bottom.pin-b {
  right: 12rpx;
}

.pin.left.pin-a,
.pin.right.pin-a {
  top: 12rpx;
}

.pin.left.pin-b,
.pin.right.pin-b {
  bottom: 12rpx;
}

.model-glyph {
  position: relative;
}

.rotor {
  position: absolute;
  width: 15rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.rotor-tl {
  left: 0;
  top: 0;
}

.rotor-tr {
  right: 0;
  top: 0;
}

.rotor-bl {
  left: 0;
  bottom: 0;
}

.rotor-br {
  right: 0;
  bottom: 0;
}

.model-core {
  position: absolute;
  left: 15rpx;
  top: 15rpx;
  width: 10rpx;
  height: 10rpx;
  border: 4rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.ai-glyph {
  position: relative;
}

.ai-line {
  position: absolute;
  width: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform-origin: top center;
}

.ai-line-main {
  left: 18rpx;
  top: 11rpx;
  height: 11rpx;
}

.ai-line-left {
  left: 18rpx;
  top: 22rpx;
  height: 17rpx;
  transform: rotate(36deg);
}

.ai-line-right {
  left: 21rpx;
  top: 22rpx;
  height: 17rpx;
  transform: rotate(-36deg);
}

.ai-node {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
  background: transparent;
}

.ai-top {
  left: 13rpx;
  top: 0;
}

.ai-left {
  left: 1rpx;
  bottom: 0;
}

.ai-right {
  right: 1rpx;
  bottom: 0;
}

.family-main {
  flex: 1;
  min-width: 0;
}

.family-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.family-title {
  color: #1a2330;
  font-size: 29rpx;
  font-weight: 900;
}

.age-pill {
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  font-size: 19rpx;
  font-weight: 900;
}

.family-desc {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 23rpx;
}

.poster-label {
  margin: 34rpx 0 18rpx;
  color: #ff5a36;
  font-family: "Menlo", "Consolas", monospace;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.poster-row {
  display: flex;
  gap: 18rpx;
  overflow: hidden;
}

.poster-row image {
  flex: 1;
  height: 220rpx;
  min-width: 0;
  border: 1rpx solid #dce3ea;
  border-radius: 18rpx;
  background: #ffffff;
}
