<view class="page course-system-page">
  <view class="page-title">课程体系</view>
  <view class="page-subtitle">5 大核心方向 · 按年龄进阶</view>

  <view class="family-list">
    <view
      class="family-card"
      wx:for="{{courseFamilies}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goCourse"
      style="border-left-color: {{item.color}};"
    >
      <view class="family-icon" style="background: {{item.soft}}; color: {{item.color}};">
        <view wx:if="{{item.id === 'brainstorm'}}" class="course-glyph robot-glyph">
          <view class="robot-eyes"><text></text><text></text></view>
          <view class="robot-mouth"></view>
        </view>
        <view wx:elif="{{item.id === 'coding'}}" class="course-glyph text-glyph">&lt;/&gt;</view>
        <view wx:elif="{{item.id === 'smart'}}" class="course-glyph chip-glyph">
          <view class="chip-pin-row"><text></text><text></text><text></text></view>
          <view class="chip-core"></view>
          <view class="chip-pin-row"><text></text><text></text><text></text></view>
        </view>
        <view wx:elif="{{item.id === 'rc'}}" class="course-glyph model-glyph">
          <view class="model-line model-line-left"></view>
          <view class="model-line model-line-right"></view>
          <text></text><text></text><text></text>
        </view>
        <view wx:else class="course-glyph text-glyph">AI</view>
      </view>
      <view class="family-main">
        <view class="family-title-row">
          <text class="family-title">{{item.title}}</text>
          <text class="age-pill" style="background: {{item.soft}}; color: {{item.color}};">{{item.age}}</text>
        </view>
        <view class="family-desc">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view class="poster-label">PBL 项目课 · 简章</view>
  <view class="poster-row">
    <image wx:for="{{posters}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
  </view>
</view>
