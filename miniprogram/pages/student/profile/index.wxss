.profile-page {
  min-height: 100vh;
  background: #f1f4f7;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 36rpx 42rpx;
  color: #ffffff;
  background: linear-gradient(150deg, #075f9b, #0079c8);
}

.hero-orb {
  position: absolute;
  top: -20rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.08);
}

.student-row {
  position: relative;
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.avatar {
  display: grid;
  place-items: center;
  width: 108rpx;
  height: 108rpx;
  border: 4rpx solid rgba(255,255,255,.6);
  border-radius: 50%;
  color: #16121f;
  background: #ffb020;
  font-size: 40rpx;
  font-weight: 900;
}

.student-name {
  font-size: 34rpx;
  font-weight: 900;
}

.level-pill {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 7rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,.18);
  font-size: 23rpx;
}

.stats {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 34rpx;
}

.stats > view {
  padding: 20rpx 10rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,.14);
  text-align: center;
}

.stats text {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
}

.stats view view {
  margin-top: 4rpx;
  color: rgba(255,255,255,.82);
  font-size: 21rpx;
}

.profile-body {
  padding-top: 28rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 30rpx 12rpx;
}

.action-item {
  text-align: center;
}

.action-icon {
  display: grid;
  place-items: center;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 10rpx;
  border-radius: 22rpx;
  font-size: 32rpx;
}

.action-item text {
  color: #5d6b7a;
  font-size: 21rpx;
  font-weight: 700;
}

.booking-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx;
}

.calendar {
  display: grid;
  place-items: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: #e8f4ff;
  font-size: 34rpx;
}

.booking-main {
  flex: 1;
  min-width: 0;
}

.booking-main view {
  color: #1a2330;
  font-size: 26rpx;
  font-weight: 800;
}

.booking-main text {
  display: block;
  margin-top: 6rpx;
  color: #8a94a3;
  font-size: 22rpx;
}

.status {
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  color: #ff5a36;
  background: #fff1ec;
  font-size: 22rpx;
  font-weight: 800;
}
