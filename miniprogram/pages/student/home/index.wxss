.campus-page {
  padding-top: 16rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 6rpx 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.brand image {
  width: 52rpx;
  height: 52rpx;
}

.brand text {
  color: #1a2330;
  font-size: 30rpx;
  font-weight: 800;
}

.city-pill {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  color: #0079c8;
  background: #e8f4ff;
  font-size: 25rpx;
  font-weight: 800;
}

.campus-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
}

.campus-bg,
.campus-wash {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.campus-bg {
  opacity: 0.14;
}

.campus-wash {
  background: linear-gradient(135deg, rgba(255,255,255,.94), rgba(255,255,255,.84));
}

.campus-main,
.campus-actions {
  position: relative;
  z-index: 1;
}

.campus-main {
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
}

.logo-box {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #075f9b, #0079c8);
}

.logo-box image {
  width: 62rpx;
  height: 62rpx;
}

.campus-info {
  flex: 1;
  min-width: 0;
}

.campus-name {
  color: #1a2330;
  font-size: 30rpx;
  font-weight: 800;
}

.campus-tag {
  margin-top: 6rpx;
  color: #0079c8;
  font-size: 23rpx;
  font-weight: 700;
}

.campus-address {
  margin-top: 10rpx;
  color: #5d6b7a;
  font-size: 23rpx;
  line-height: 1.45;
}

.campus-phone {
  margin-top: 10rpx;
  color: #ff5a36;
  font-size: 23rpx;
  font-weight: 800;
}

.campus-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.season-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.featured-card {
  overflow: hidden;
}

.featured-banner {
  position: relative;
  display: grid;
  place-items: center;
  height: 92rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #075f9b, #0aa0e0);
}

.featured-banner image {
  width: 54rpx;
  height: 54rpx;
  opacity: 0.95;
}

.featured-banner text {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 22rpx;
  color: #075f9b;
  background: rgba(255,255,255,.92);
  font-size: 21rpx;
  font-weight: 800;
}

.featured-body {
  padding: 22rpx 26rpx 24rpx;
}

.featured-title {
  color: #1a2330;
  font-size: 30rpx;
  font-weight: 800;
}

.featured-meta {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 23rpx;
}

.featured-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.featured-bottom text {
  color: #5d6b7a;
  font-size: 23rpx;
}

.featured-bottom button {
  flex: 0 0 auto;
  min-width: 108rpx;
  min-height: 56rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #ff5a36;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.honor-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #f3e0b6;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff6e6, #ffeccc);
}

.honor-icon {
  font-size: 36rpx;
}

.honor-copy {
  flex: 1;
  min-width: 0;
}

.honor-copy view {
  color: #7a5a16;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.honor-copy text {
  display: block;
  margin-top: 4rpx;
  color: #a98a4a;
  font-size: 21rpx;
  font-weight: 700;
}
