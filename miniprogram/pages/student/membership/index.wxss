.makerseed-page {
  padding: 0 0 56rpx;
}

.subnav {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 28rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #eef1f4;
}

.sub-title {
  flex-shrink: 0;
  color: #1a2330;
  font-size: 27rpx;
  font-weight: 900;
}

.toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  flex: 1;
  gap: 6rpx;
  padding: 6rpx;
  border-radius: 22rpx;
  background: #eef1f4;
}

.toggle view {
  display: grid;
  place-items: center;
  min-height: 52rpx;
  border-radius: 16rpx;
  color: #8a94a3;
  font-size: 23rpx;
  font-weight: 800;
}

.toggle .active {
  color: #0079c8;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(15, 30, 55, 0.08);
}

.dark-head {
  position: relative;
  overflow: hidden;
  padding: 30rpx 28rpx 28rpx;
  color: #ffffff;
  background: #0c1a26;
}

.dark-head image {
  position: absolute;
  right: -28rpx;
  bottom: -28rpx;
  width: 180rpx;
  height: 180rpx;
  opacity: .16;
}

.company {
  position: relative;
  font-size: 32rpx;
  font-weight: 900;
}

.badge-row {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.badge-row text {
  padding: 10rpx 22rpx;
  border: 1rpx solid rgba(95, 192, 255, .32);
  border-radius: 24rpx;
  color: #bfe3ff;
  background: rgba(95, 192, 255, .16);
  font-size: 21rpx;
  font-weight: 800;
}

.content-wrap {
  padding: 22rpx 28rpx 0;
}

.mono-label {
  margin: 28rpx 0 16rpx;
}

.blue {
  color: #0079c8;
}

.gold {
  color: #e09100;
}

.green {
  color: #247d34;
}

.license-list,
.faculty-list {
  display: grid;
  gap: 14rpx;
}

.faculty-list {
  gap: 18rpx;
}

.license {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 28rpx;
  box-shadow: none;
}

.license-icon {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.license-icon.shield {
  color: #de3b2f;
  background: #f8edf0;
}

.license-icon.power {
  color: #f0a008;
  background: #fff1ec;
}

.license view {
  flex: 1;
  color: #1a2330;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.4;
}

.honor-list {
  padding: 0 24rpx;
}

.honor-list > view {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f4f7;
}

.honor-list > view:last-child {
  border-bottom: 0;
}

.honor-list text {
  color: #e09100;
  font-size: 26rpx;
  font-weight: 900;
}

.honor-list view view {
  color: #3a4655;
  font-size: 24rpx;
  line-height: 1.4;
}

.photo-strip {
  display: flex;
  gap: 10rpx;
  overflow: hidden;
}

.photo-strip > view {
  flex: 1;
  position: relative;
  overflow: hidden;
  height: 106rpx;
  border-radius: 18rpx;
}

.photo-strip image {
  width: 100%;
  height: 100%;
}

.photo-strip text {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 26rpx 14rpx 12rpx;
  color: #ffffff;
  background: linear-gradient(transparent, rgba(15, 12, 20, .75));
  font-size: 21rpx;
  font-weight: 800;
}

.school-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.school-tags text {
  padding: 11rpx 22rpx;
  border-radius: 22rpx;
  color: #5d6b7a;
  background: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.faculty-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 20rpx 24rpx;
  box-shadow: none;
}

.faculty-card image {
  flex: 0 0 auto;
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
}

.faculty-main {
  flex: 1;
  min-width: 0;
}

.name {
  color: #1a2330;
  font-size: 28rpx;
  font-weight: 900;
}

.role {
  margin-top: 4rpx;
  color: #ff5a36;
  font-size: 21rpx;
  font-weight: 800;
}

.desc {
  margin-top: 5rpx;
  color: #8a94a3;
  font-size: 20rpx;
  line-height: 1.35;
}

.rnd-card {
  overflow: hidden;
  box-shadow: none;
}

.rnd-card image {
  display: block;
  width: 100%;
  max-height: 300rpx;
}

.rnd-bottom {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 24rpx;
}

.rnd-bottom text {
  color: #5d6b7a;
  font-size: 22rpx;
  font-weight: 700;
}

.rnd-bottom view {
  color: #0079c8;
  font-size: 22rpx;
  font-weight: 800;
}
