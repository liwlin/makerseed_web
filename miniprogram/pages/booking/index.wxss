.tip {
  padding: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  background: linear-gradient(135deg, #075f9b 0%, #0079c8 100%);
  font-size: 27rpx;
  line-height: 1.65;
}

.tip image {
  width: 360rpx;
  height: 110rpx;
  margin-bottom: 18rpx;
}

.form {
  display: grid;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 28rpx;
}

.field {
  display: grid;
  gap: 10rpx;
}

.label {
  color: #223348;
  font-size: 27rpx;
  font-weight: 850;
}

input,
textarea,
.picker-value {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #d9e4ee;
  border-radius: 14rpx;
  color: #111827;
  background: #fbfdff;
  font-size: 28rpx;
}

textarea {
  min-height: 170rpx;
}

.picker-value {
  color: #637083;
}

.submit {
  margin-top: 8rpx;
}
