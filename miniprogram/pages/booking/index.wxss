.tip {
  padding: 30rpx;
  color: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4b1f68 0%, #8f3dd6 100%);
  font-size: 27rpx;
  line-height: 1.65;
}

.tip image {
  width: 360rpx;
  height: 110rpx;
  margin-bottom: 18rpx;
}

.campus-line {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.form {
  display: grid;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.field {
  display: grid;
  gap: 10rpx;
}

.label {
  color: #223348;
  font-size: 27rpx;
  font-weight: 850;
}

input,
textarea,
.picker-value {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border: 0;
  border-radius: 18rpx;
  color: #111827;
  background: #f5f5f5;
  font-size: 28rpx;
}

textarea {
  min-height: 170rpx;
}

.picker-value {
  color: #637083;
}

.submit {
  margin-top: 8rpx;
}
