<view class="page">
  <view class="section-title">课程与项目</view>
  <view class="tabs">
    <view
      class="tab {{activeCategory === item.value ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="value"
      data-value="{{item.value}}"
      bindtap="changeCategory"
    >{{item.label}}</view>
  </view>

  <view class="course-list">
    <view class="course-card card" wx:for="{{visibleCourses}}" wx:key="title">
      <view class="course-top">
        <view class="course-tag">{{item.tag}}</view>
        <view class="course-age">{{item.age}}</view>
      </view>
      <view class="course-title">{{item.title}}</view>
      <view class="course-summary">{{item.summary}}</view>
      <view class="course-points">
        <view class="course-point" wx:for="{{item.points}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="course-actions">
        <button class="primary-button mini" data-title="{{item.title}}" bindtap="bookCourse">预约</button>
        <button class="ghost-button mini" data-url="{{item.link}}" bindtap="copyLink">复制原文链接</button>
      </view>
    </view>
  </view>
</view>
