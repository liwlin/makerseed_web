.tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab {
  flex: 0 0 auto;
  min-height: 68rpx;
  padding: 14rpx 22rpx;
  border: 1rpx solid #d9e4ee;
  border-radius: 14rpx;
  color: #34465a;
  background: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
}

.tab.active {
  color: #ffffff;
  background: #0079c8;
  border-color: #0079c8;
}

.course-list {
  display: grid;
  gap: 20rpx;
}

.course-card {
  padding: 26rpx;
}

.course-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-tag {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  color: #075f9b;
  background: #e8f5ff;
  font-size: 22rpx;
  font-weight: 900;
}

.course-age {
  color: #637083;
  font-size: 24rpx;
  font-weight: 800;
}

.course-title {
  margin-top: 18rpx;
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 900;
}

.course-summary {
  margin-top: 12rpx;
  color: #5d6b7a;
  font-size: 27rpx;
  line-height: 1.65;
}

.course-points {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.course-point {
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  color: #26384d;
  background: #f2f7fb;
  font-size: 24rpx;
}

.course-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.mini {
  min-height: 78rpx;
  font-size: 27rpx;
  line-height: 78rpx;
}
