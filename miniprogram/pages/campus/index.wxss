.campus-page {
  min-height: 100vh;
  padding-bottom: 44rpx;
  background: #eeeeee;
}

.hero-card {
  position: relative;
  height: 520rpx;
  padding: 44rpx 30rpx;
  overflow: hidden;
  border-bottom-right-radius: 36rpx;
  border-bottom-left-radius: 36rpx;
  color: #ffffff;
}

.hero-image,
.hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.16), rgba(0, 0, 0, 0.42));
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-pill {
  min-height: 66rpx;
  padding: 15rpx 24rpx;
  border-radius: 34rpx;
  color: #111111;
  background: rgba(255, 255, 255, 0.72);
  font-size: 30rpx;
  font-weight: 850;
}

.wechat-pill {
  min-height: 58rpx;
  padding: 12rpx 24rpx;
  border-radius: 34rpx;
  color: #111111;
  background: rgba(255, 255, 255, 0.74);
  font-size: 28rpx;
  font-weight: 900;
}

.hero-copy {
  position: absolute;
  right: 34rpx;
  bottom: 82rpx;
  left: 34rpx;
  z-index: 1;
}

.hero-logo {
  width: 360rpx;
  height: 110rpx;
  padding: 10rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
}

.hero-subtitle {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}

.hero-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 36rpx;
}

.hero-tools text {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  color: #4b1f68;
  background: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  font-weight: 850;
}

.city-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  width: 650rpx;
  min-height: 100rpx;
  margin: -52rpx auto 54rpx;
  padding: 10rpx;
}

.city-tab {
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #666666;
  font-size: 32rpx;
  font-weight: 850;
}

.city-tab.active {
  color: #4b1f68;
}

.campus-heading {
  width: 650rpx;
  margin: 0 auto 30rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
}

.campus-heading text {
  display: block;
}

.campus-heading .orange {
  display: inline;
  color: #ff5a36;
}

.campus-list {
  display: grid;
  gap: 34rpx;
  width: 650rpx;
  margin: 0 auto;
}

.campus-card {
  overflow: hidden;
}

.campus-photo {
  width: 100%;
  height: 320rpx;
  display: block;
}

.campus-body {
  padding: 24rpx 30rpx 30rpx;
}

.campus-name {
  color: #4b1f68;
  font-size: 32rpx;
  font-weight: 900;
}

.campus-address {
  margin-top: 8rpx;
  color: #8a8a8a;
  font-size: 26rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-row text {
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  color: #0079c8;
  background: #e9f5fe;
  font-size: 22rpx;
  font-weight: 850;
}

.campus-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.small {
  min-height: 76rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.story-section {
  width: 650rpx;
  margin: 48rpx auto 0;
}

.story-card {
  display: grid;
  grid-template-columns: 190rpx 1fr;
  gap: 24rpx;
  align-items: center;
  min-height: 170rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.story-card image {
  width: 190rpx;
  height: 124rpx;
  border-radius: 10rpx;
}

.story-title {
  font-size: 32rpx;
  font-weight: 950;
}

.story-desc {
  margin-top: 10rpx;
  color: #777777;
  font-size: 26rpx;
  line-height: 1.35;
}
