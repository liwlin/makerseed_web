.campus-page {
  min-height: 100vh;
  padding-bottom: 44rpx;
  background: #eeeeee;
}

.hero-card {
  position: relative;
  min-height: 500rpx;
  padding: 48rpx 34rpx 42rpx;
  overflow: hidden;
  border-bottom-right-radius: 36rpx;
  border-bottom-left-radius: 36rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff9632 0%, #ff5a36 72%);
}

.hero-card::after {
  position: absolute;
  right: -130rpx;
  bottom: -160rpx;
  width: 520rpx;
  height: 520rpx;
  border: 34rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  content: "";
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-pill {
  min-height: 66rpx;
  padding: 15rpx 24rpx;
  border-radius: 34rpx;
  color: #111111;
  background: rgba(255, 255, 255, 0.72);
  font-size: 30rpx;
  font-weight: 850;
}

.hero-logo {
  width: 128rpx;
  height: 128rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 76rpx;
  font-size: 66rpx;
  font-weight: 950;
  line-height: 1;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}

.hero-tools {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 36rpx;
}

.hero-tools text {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  color: #4b1f68;
  background: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  font-weight: 850;
}

.city-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  width: 650rpx;
  min-height: 100rpx;
  margin: -52rpx auto 54rpx;
  padding: 10rpx;
}

.city-tab {
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #666666;
  font-size: 32rpx;
  font-weight: 850;
}

.city-tab.active {
  color: #4b1f68;
}

.campus-heading {
  width: 650rpx;
  margin: 0 auto 30rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
}

.campus-heading text {
  display: block;
}

.campus-heading .orange {
  display: inline;
  color: #ff5a36;
}

.campus-list {
  display: grid;
  gap: 34rpx;
  width: 650rpx;
  margin: 0 auto;
}

.campus-card {
  overflow: hidden;
}

.campus-photo {
  display: grid;
  place-items: center;
  min-height: 270rpx;
  padding: 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4b1f68 0%, #8f3dd6 100%);
  font-size: 26rpx;
  font-weight: 850;
}

.campus-photo image {
  width: 390rpx;
  height: 120rpx;
  margin-bottom: 12rpx;
}

.campus-body {
  padding: 24rpx 30rpx 30rpx;
}

.campus-name {
  color: #4b1f68;
  font-size: 32rpx;
  font-weight: 900;
}

.campus-address,
.campus-summary {
  margin-top: 8rpx;
  color: #8a8a8a;
  font-size: 26rpx;
  line-height: 1.45;
}

.campus-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.small {
  min-height: 76rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}
