.hero {
  padding: 34rpx 30rpx;
  overflow: hidden;
}

.hero-logo {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto 20rpx;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: 900;
}

.hero-text {
  margin-top: 18rpx;
  color: #5d6b7a;
  font-size: 29rpx;
  line-height: 1.7;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-item {
  padding: 24rpx;
}

.quick-mark {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  color: #075f9b;
  background: #e8f5ff;
  font-size: 22rpx;
  font-weight: 900;
}

.quick-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 850;
}

.quick-text {
  margin-top: 8rpx;
  color: #637083;
  font-size: 27rpx;
  line-height: 1.55;
}

.loop {
  padding: 8rpx 24rpx;
}

.loop-item {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e6eef6;
}

.loop-item:last-child {
  border-bottom: 0;
}

.loop-index {
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #0079c8;
  text-align: center;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.loop-title {
  font-size: 31rpx;
  font-weight: 850;
}

.loop-text {
  margin-top: 6rpx;
  color: #637083;
  font-size: 26rpx;
  line-height: 1.6;
}
