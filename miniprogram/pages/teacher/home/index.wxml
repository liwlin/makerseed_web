<view class="page">
  <view class="section-title">今日课程</view>
  <view class="teacher-card card" wx:for="{{lessons}}" wx:key="_id" data-id="{{item._id}}" bindtap="goCheckin">
    <view>
      <view class="item-title">{{item.time}} · {{item.course}}</view>
      <text>{{item.student}} · {{item.status}}</text>
    </view>
    <button>签到</button>
  </view>
  <button class="soft-button nav-button" bindtap="goSchedule">查看完整课表</button>
</view>
