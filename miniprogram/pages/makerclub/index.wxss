.club-head {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 26rpx;
  align-items: center;
  padding: 34rpx 34rpx;
}

.club-head image {
  width: 132rpx;
  height: 132rpx;
}

.club-title {
  color: #4b1f68;
  font-size: 36rpx;
  font-weight: 950;
}

.club-title text {
  color: #ff5a36;
}

.price-pill {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #ff9632, #ff5a36);
  font-size: 25rpx;
  font-weight: 850;
}

.club-note {
  margin-top: 16rpx;
  color: #888888;
  font-size: 25rpx;
  font-weight: 750;
}

.benefit-card {
  margin-top: 26rpx;
  padding: 36rpx 28rpx;
}

.benefit-title {
  color: #4b1f68;
  font-size: 38rpx;
  font-weight: 950;
  text-align: center;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 34rpx;
}

.benefit-item {
  display: grid;
  place-items: center;
  min-height: 160rpx;
  padding: 18rpx 8rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx #eeeeee, 0 10rpx 22rpx rgba(0, 0, 0, 0.06);
  color: #333333;
  font-size: 26rpx;
  font-weight: 850;
}

.benefit-icon {
  display: grid;
  place-items: center;
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #d6ab4a;
  font-weight: 950;
}

.empty-card {
  margin-top: 28rpx;
  padding: 34rpx;
  color: #888888;
  font-size: 30rpx;
  font-weight: 850;
  text-align: center;
}

.bind-button {
  margin-top: 28rpx;
}
