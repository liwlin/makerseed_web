<view class="page club-page">
  <view class="club-head card">
    <image src="/images/media/brand/logo.png" mode="aspectFit"></image>
    <view class="club-copy">
      <view class="club-title"><text>{{siteConfig.englishName}}</text> {{siteConfig.membershipName}}会员权益</view>
      <view class="price-pill">首购权益折扣价：到店咨询</view>
      <view class="club-note">仅常规课在读学员可购买</view>
    </view>
  </view>

  <view class="benefit-card card">
    <view class="benefit-title">会员专享 7 大权益</view>
    <view class="benefit-grid">
      <view class="benefit-item" wx:for="{{memberBenefits}}" wx:key="title">
        <view class="benefit-icon">{{item.icon}}</view>
        <view>{{item.title}}</view>
      </view>
    </view>
  </view>

  <view class="empty-card card">
    <view>您还没有绑定在读学员，暂时无法购买</view>
    <button class="primary-button bind-button" bindtap="goProfile">去我的页面绑定</button>
  </view>
</view>
