.manage-page {
  padding-top: 56rpx;
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 500rpx;
  min-height: 86rpx;
  margin: 0 auto;
  padding: 10rpx;
  border-radius: 24rpx;
  background: #dddddd;
}

.segment {
  display: grid;
  place-items: center;
  border-radius: 18rpx;
  color: #333333;
  font-size: 28rpx;
  font-weight: 850;
}

.segment.active {
  color: #ff5a36;
  background: #ffffff;
}

.empty-box {
  width: 610rpx;
  margin: 150rpx auto 0;
  padding: 54rpx 30rpx;
  border-radius: 20rpx;
  background: #fffaf7;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.empty-text {
  color: #777777;
  font-size: 34rpx;
  font-weight: 850;
}

.signup-button {
  margin-top: 40rpx;
}

.managed-list {
  display: grid;
  gap: 24rpx;
  margin-top: 56rpx;
}

.managed-card {
  padding: 30rpx;
}

.managed-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.managed-title {
  color: #4b1f68;
  font-size: 34rpx;
  font-weight: 950;
}

.managed-subtitle {
  margin-top: 8rpx;
  color: #888888;
  font-size: 26rpx;
}

.managed-status {
  padding: 8rpx 18rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #ff5a36;
  font-size: 24rpx;
  font-weight: 900;
}

.managed-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid #eeeeee;
  color: #777777;
  font-size: 26rpx;
}

.managed-row text:last-child {
  max-width: 420rpx;
  color: #333333;
  text-align: right;
}

.managed-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.mini {
  min-height: 76rpx;
  font-size: 27rpx;
  line-height: 76rpx;
}

.clear-button {
  margin-top: 8rpx;
}

.system-card {
  margin-top: 44rpx;
  padding: 30rpx;
}

.system-title {
  color: #4b1f68;
  font-size: 36rpx;
  font-weight: 950;
}

.system-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 27rpx;
  line-height: 1.55;
}

.system-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.system-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 64rpx;
  color: #333333;
  font-size: 25rpx;
  font-weight: 900;
}

.system-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
}

.project-list {
  margin-top: 44rpx;
}

.project-row {
  display: grid;
  grid-template-columns: 150rpx 1fr 112rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 142rpx;
  margin-top: 22rpx;
  padding: 18rpx;
}

.project-row image {
  width: 150rpx;
  height: 100rpx;
  border-radius: 12rpx;
}

.project-title {
  color: #4b1f68;
  font-size: 28rpx;
  font-weight: 950;
}

.project-subtitle {
  margin-top: 8rpx;
  color: #777777;
  font-size: 23rpx;
  line-height: 1.35;
}
