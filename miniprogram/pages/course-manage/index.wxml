<view class="page manage-page">
  <view class="segmented">
    <view
      class="segment {{active === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      data-value="{{item.value}}"
      bindtap="switchTab"
    >{{item.label}}</view>
  </view>

  <view wx:if="{{visibleCourses.length}}" class="managed-list">
    <view class="managed-card card" wx:for="{{visibleCourses}}" wx:key="createdAt">
      <view class="managed-top">
        <view>
          <view class="managed-title">{{item.interest}}</view>
          <view class="managed-subtitle">{{item.student}} · {{item.age}} 岁 · {{item.grade || '未填写年级'}}</view>
        </view>
        <view class="managed-status">{{item.status || '意向'}}</view>
      </view>
      <view class="managed-row">
        <text>校区</text>
        <text>{{item.campus || siteConfig.campusName}}</text>
      </view>
      <view class="managed-row" wx:if="{{item.note}}">
        <text>备注</text>
        <text>{{item.note}}</text>
      </view>
      <view class="managed-row">
        <text>提交时间</text>
        <text>{{item.createdAt}}</text>
      </view>
      <view class="managed-actions">
        <button class="ghost-button mini" data-title="{{item.interest}}" bindtap="goBooking">补充资料</button>
        <button class="primary-button mini" data-title="{{item.interest}}" bindtap="goBooking">预约沟通</button>
      </view>
    </view>
    <button class="ghost-button clear-button" bindtap="clearBookings">清空测试数据</button>
  </view>

  <view wx:else class="empty-box">
    <view class="empty-text">暂无课程数据哦~</view>
    <button class="primary-button signup-button" bindtap="goSignup">去报名课程</button>
  </view>

  <view class="system-card card">
    <view class="system-title">课程体系</view>
    <view class="system-desc">从创客启蒙到 AI 创意应用，用项目制路径承接常规课、营期和竞赛集训。</view>
    <view class="system-grid">
      <view class="system-item" wx:for="{{courseFamilies}}" wx:key="id">
        <view class="system-dot" style="background: {{item.color}};"></view>
        <view>{{item.title}}</view>
      </view>
    </view>
  </view>

  <view class="project-list">
    <view class="section-title">可预约项目</view>
    <view class="project-row card" wx:for="{{projectPosters}}" wx:key="title">
      <image src="{{item.image}}" mode="aspectFill"></image>
      <view>
        <view class="project-title">{{item.title}}</view>
        <view class="project-subtitle">{{item.subtitle}}</view>
      </view>
      <button class="primary-button mini" data-title="{{item.title}}" bindtap="goBooking">预约</button>
    </view>
  </view>
</view>
