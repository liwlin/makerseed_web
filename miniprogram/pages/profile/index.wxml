<view class="page">
  <view class="profile-head card">
    <image src="/images/logo.png" mode="aspectFit"></image>
    <view>
      <view class="profile-title">种子创客工坊</view>
      <view class="profile-subtitle">造物立志，认识世界，改变世界</view>
    </view>
  </view>

  <view class="actions">
    <button class="primary-button" bindtap="goBooking">新增预约</button>
    <button class="ghost-button" bindtap="copyWechat">复制公众号名称</button>
  </view>

  <view class="section-title">预约记录</view>
  <view wx:if="{{bookings.length}}" class="booking-list">
    <view class="booking-card card" wx:for="{{bookings}}" wx:key="createdAt">
      <view class="booking-title">{{item.student}} · {{item.interest}}</view>
      <view class="booking-line">年龄：{{item.age}}</view>
      <view class="booking-line">电话：{{item.phone}}</view>
      <view class="booking-line">时间：{{item.createdAt}}</view>
      <view class="booking-note" wx:if="{{item.note}}">{{item.note}}</view>
    </view>
    <button class="ghost-button clear" bindtap="clearBookings">清空记录</button>
  </view>

  <view wx:else class="empty card">
    <view>还没有预约记录</view>
    <view class="empty-sub">可以先去课程页选择方向，或直接新增预约。</view>
  </view>
</view>
