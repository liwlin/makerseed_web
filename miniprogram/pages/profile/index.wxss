.profile-top {
  display: grid;
  grid-template-columns: 120rpx 1fr 150rpx;
  gap: 22rpx;
  align-items: center;
  margin-top: 28rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.10);
}

.nickname {
  font-size: 38rpx;
  font-weight: 900;
}

.top-icons {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  color: #8f3dd6;
  font-size: 44rpx;
}

.level-card {
  margin-top: 46rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #4b1f68;
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.16);
}

.level-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.level-title {
  font-size: 38rpx;
  font-weight: 950;
}

.level-row button {
  min-width: 220rpx;
  min-height: 58rpx;
  border-radius: 30rpx;
  color: #ffffff;
  background: #9a42df;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 58rpx;
}

.progress {
  position: relative;
  height: 44rpx;
  margin-top: 38rpx;
}

.progress-line {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  left: 20rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.progress-dot {
  position: absolute;
  z-index: 1;
  top: 8rpx;
  left: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ff9632;
}

.level-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  font-size: 25rpx;
  font-weight: 850;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 36rpx 0;
  text-align: center;
}

.stats > view {
  border-right: 1rpx solid #ffffff;
}

.stats > view:last-child {
  border-right: 0;
}

.stats text {
  color: #ff5a36;
  font-size: 38rpx;
  font-weight: 950;
}

.stats view view {
  color: #111111;
  font-size: 26rpx;
  font-weight: 850;
}

.profile-banner {
  display: grid;
  place-items: center;
  min-height: 190rpx;
  padding: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #6b4a2d, #1d3557);
  text-align: center;
}

.profile-banner view {
  font-size: 38rpx;
  font-weight: 950;
}

.profile-banner text {
  margin-top: 8rpx;
  font-size: 25rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  margin-top: 34rpx;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 0 22rpx 0 34rpx;
  border-radius: 24rpx;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, 0.14);
}

.action-card.purple {
  background: #4b1f68;
}

.action-card.orange {
  background: #ff5a36;
}

.action-card view {
  font-size: 32rpx;
  font-weight: 950;
}

.action-card text {
  display: grid;
  place-items: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  font-weight: 950;
}

.booking-preview {
  margin-top: 34rpx;
  padding: 28rpx;
}

.preview-title {
  color: #4b1f68;
  font-size: 30rpx;
  font-weight: 950;
}

.preview-line {
  margin-top: 8rpx;
  color: #777777;
  font-size: 26rpx;
}

.version {
  margin-top: 34rpx;
  color: #cccccc;
  font-size: 24rpx;
  text-align: center;
}
