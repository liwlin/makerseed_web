.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx;
}

.profile-head image {
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 120rpx;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 900;
}

.profile-subtitle {
  margin-top: 8rpx;
  color: #637083;
  font-size: 26rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.booking-list {
  display: grid;
  gap: 18rpx;
}

.booking-card {
  padding: 24rpx;
}

.booking-title {
  font-size: 31rpx;
  font-weight: 900;
}

.booking-line,
.booking-note {
  margin-top: 10rpx;
  color: #5d6b7a;
  font-size: 26rpx;
  line-height: 1.55;
}

.booking-note {
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f2f7fb;
}

.clear {
  margin-top: 8rpx;
}

.empty {
  padding: 34rpx;
  color: #34465a;
  font-size: 30rpx;
  font-weight: 850;
  text-align: center;
}

.empty-sub {
  margin-top: 10rpx;
  color: #637083;
  font-size: 26rpx;
  font-weight: 400;
}
