.empty {
  margin-top: 24rpx;
  padding: 44rpx;
  color: #8a94a3;
  text-align: center;
}
.booking-card {
  margin-top: 18rpx;
  padding: 28rpx;
}
.booking-title {
  color: #1a2330;
  font-size: 29rpx;
  font-weight: 900;
}
.booking-meta {
  margin-top: 8rpx;
  color: #8a94a3;
  font-size: 23rpx;
}
.actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}
.actions button {
  min-height: 58rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #0079c8;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 58rpx;
}
