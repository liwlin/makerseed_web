<view class="page">
  <view class="section-title">学员管理</view>
  <view wx:if="{{!students.length}}" class="empty card">暂无学员数据</view>
  <view class="list-card" wx:for="{{students}}" wx:key="_id">
    <view>
      <view class="item-title">{{item.name}}</view>
      <text>{{item.grade}} · {{item.interests}}</text>
    </view>
  </view>
</view>
