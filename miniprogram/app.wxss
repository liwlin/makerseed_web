page {
  min-height: 100%;
  color: #1a2330;
  background: #f1f4f7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
  background: #f1f4f7;
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(15, 30, 55, 0.06);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 24rpx 0 18rpx;
}

.section-title {
  color: #1a2330;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-more {
  color: #8a94a3;
  font-size: 22rpx;
  font-weight: 700;
}

.mono-label {
  color: #0079c8;
  font-family: "Menlo", "Consolas", monospace;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.primary-button {
  display: grid;
  place-items: center;
  min-height: 80rpx;
  border-radius: 40rpx;
  color: #ffffff;
  background: #ff5a36;
  box-shadow: 0 10rpx 22rpx rgba(255, 90, 54, 0.24);
  font-size: 29rpx;
  font-weight: 800;
  line-height: 80rpx;
}

.blue-button {
  display: grid;
  place-items: center;
  min-height: 72rpx;
  border-radius: 36rpx;
  color: #ffffff;
  background: #0079c8;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.soft-button {
  display: grid;
  place-items: center;
  min-height: 72rpx;
  border-radius: 36rpx;
  color: #0079c8;
  background: #e8f4ff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  color: #5d6b7a;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.chip.active {
  color: #ffffff;
  background: #0079c8;
}

.list-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.muted {
  color: #8a94a3;
}

.brand-blue {
  color: #0079c8;
}

.action-orange {
  color: #ff5a36;
}
