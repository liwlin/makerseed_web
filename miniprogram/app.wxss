page {
  min-height: 100%;
  color: #111827;
  background: #f7fbff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.section-title {
  margin: 38rpx 0 20rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
}

.eyebrow {
  color: #0079c8;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: uppercase;
}

.card {
  border: 1rpx solid #d9e4ee;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(9, 35, 63, 0.08);
}

.primary-button {
  min-height: 92rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #0079c8;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
}

.ghost-button {
  min-height: 88rpx;
  border: 1rpx solid #d9e4ee;
  border-radius: 16rpx;
  color: #075f9b;
  background: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
}
